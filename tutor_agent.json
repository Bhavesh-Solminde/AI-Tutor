                "collection": "Topics",
                "fields": "={{ $json.message.content }}",
                "options": {}
            },
            "id": "38c4ce1e-736f-46dc-929f-2147eb2b86cc",
            "name": "MongoDB (Save Topics)",
            "type": "n8n-nodes-base.mongoDb",
