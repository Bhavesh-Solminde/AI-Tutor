        {
            "parameters": {
                "jsCode": "try {\n  var raw = $input.item.json.output || '{}';\n  raw = raw.replace(/^```json\\s*/i, '').replace(/^```\\s*/i, '').replace(/\\s*```$/i, '').trim();\n  var parsed = JSON.parse(raw);\n  return {\n    explanation: parsed.explanation || '',\n    checkpoint_question: parsed.checkpoint_question || '',\n    doubt_prompt: parsed.doubt_prompt || 'Do you have any doubts?',\n    next_action: parsed.next_action || 'CONTINUE',\n    explanation_mode: parsed.explanation_mode || 'standard'\n  };\n} catch(e) {\n  return { error: 'Parse failed', raw: $input.item.json.output, details: e.message };\n}"
            },
