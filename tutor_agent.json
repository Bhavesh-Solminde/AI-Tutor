            "id": "211cef62-a975-451a-85d7-507de03c9851",
            "name": "Recursive Character Text Splitter",
            "type": "@n8n/n8n-nodes-langchain.textSplitterRecursiveCharacterTextSplitter",
            "typeVersion": 1,
            "position": [
                -432,
                3456
            ]
        },
        {
            "parameters": {
                "jsCode": "var text = $input.item.json.text || $input.item.json.data || '';\nvar fileName = ($input.item.binary && $input.item.binary.data && $input.item.binary.data.fileName) ? $input.item.binary.data.fileName : '';\nvar isPdf = fileName.toLowerCase().endsWith('.pdf');\n\nvar topics = [];\n\nif (!isPdf) {\n  // MD / TXT: extract markdown headings (# ## ###)\n  var lines = text.split('\\n');\n  for (var i = 0; i < lines.length; i++) {\n    var line = lines[i].trim();\n    var match = line.match(/^#{1,3}\\s+(.+)$/);\n    if (match && match[1].length > 2) {\n      var topicName = match[1].replace(/\\[([^\\]]+)\\]\\([^)]+\\)/g, '$1').replace(/#/g, '').trim();\n      if (topicName && !topics.find(function(t) { return t.name === topicName; })) {\n        topics.push({ name: topicName, difficulty: 'medium', estimatedMinutes: 30 });\n      }\n    }\n  }\n} else {\n  // PDF: look for ALL-CAPS lines or lines ending with colon (chapter/section markers)\n  var pdfLines = text.split('\\n');\n  for (var j = 0; j < pdfLines.length; j++) {\n    var pl = pdfLines[j].trim();\n    // Skip very short lines, page numbers, or lines that are purely numeric\n    if (pl.length < 4 || /^\\d+$/.test(pl)) continue;\n    var isHeading = (pl === pl.toUpperCase() && pl.length > 4 && pl.length < 80) ||\n                   (pl.endsWith(':') && pl.length < 80 && pl.split(' ').length <= 8);\n    if (isHeading && !topics.find(function(t) { return t.name === pl; })) {\n      topics.push({ name: pl.replace(/:$/, '').trim(), difficulty: 'medium', estimatedMinutes: 30 });\n    }\n  }\n}\n\n// Cap at 20 topics\nif (topics.length > 20) topics = topics.slice(0, 20);\n\n// Fallback if nothing found\nif (topics.length === 0) {\n  var firstLine = text.split('\\n').find(function(l) { return l.trim().length > 4; }) || 'Document Content';\n  topics = [{ name: firstLine.trim().substring(0, 60), difficulty: 'medium', estimatedMinutes: 30 }];\n}\n\nreturn { message: { content: JSON.stringify({ topics: topics }) } };"
            },
            "id": "a3e95e3f-56d0-431e-a9d9-901290a931f5",
            "name": "OpenAI Topic Extractor",
            "type": "n8n-nodes-base.code",
