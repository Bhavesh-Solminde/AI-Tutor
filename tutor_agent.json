        {
            "parameters": {
                "jsCode": "var text = $input.item.json.text || $input.item.json.data || '';\n\n// Extract ## and ### headings as topics\nvar topics = [];\nvar lines = text.split('\\n');\nfor (var i = 0; i < lines.length; i++) {\n  var line = lines[i].trim();\n  var match = line.match(/^#{1,3}\\s+(.+)$/);\n  if (match && match[1].length > 2) {\n    var topicName = match[1].replace(/\\[([^\\]]+)\\]\\([^)]+\\)/g, '$1').replace(/#/g, '').trim();\n    if (topicName && !topics.find(function(t) { return t.name === topicName; })) {\n      topics.push({ name: topicName, difficulty: 'medium', estimatedMinutes: 30 });\n    }\n  }\n}\n\n// Cap at 20 topics\nif (topics.length > 20) topics = topics.slice(0, 20);\n\n// Fallback if no headings found (e.g. plain PDF text)\nif (topics.length === 0) {\n  topics = [{ name: 'Document Content', difficulty: 'medium', estimatedMinutes: 30 }];\n}\n\nreturn { message: { content: JSON.stringify({ topics: topics }) } };"
            },
            "id": "37816ed5-fe5a-4e65-8318-4756e8f3aa25",
            "name": "OpenAI Topic Extractor",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                -48,
