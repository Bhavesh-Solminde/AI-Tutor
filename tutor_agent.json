        },
        {
            "parameters": {
                "jsCode": "try {\n  // Read from Topic Extractor node directly — MongoDB output doesn't carry message.content\n  var topicNode = $('OpenAI Topic Extractor').item.json;\n  var rawContent = (topicNode.message && topicNode.message.content) ? topicNode.message.content : '{\"topics\": []}';\n  var extractedData = JSON.parse(rawContent);\n  var topics = extractedData.topics || [];\n  var roadmapNodes = topics.map(function(topic, index) {\n    return {\n      id: 'topic-' + index,\n      label: typeof topic === 'string' ? topic : (topic.name || 'Topic ' + (index + 1)),\n      status: 'unstarted',\n      position: { x: 250, y: index * 120 },\n      difficulty: topic.difficulty || 'medium',\n      estimatedMinutes: topic.estimatedMinutes || 30\n    };\n  });\n  return { topics: topics, roadmapNodes: roadmapNodes };\n} catch (error) {\n  return { topics: [], roadmapNodes: [], error: error.message };\n}"
            },
