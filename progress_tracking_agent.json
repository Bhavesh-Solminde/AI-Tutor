        {
            "parameters": {
                "jsCode": "var body = $input.item.json.body;\nvar quizScore = body.quizResults.score / body.quizResults.total;\nvar selfRating = body.selfRatingAfter / 10;\nvar estimatedMinutes = body.estimatedMinutes || 30;\nvar engagement = Math.min(body.sessionDurationMinutes / estimatedMinutes, 1.0);\n\nvar calculatedMastery = Math.round((quizScore * 0.6 + selfRating * 0.3 + engagement * 0.1) * 100);\nvar previousMastery = body.previousMasteryScore || 0;\nvar passed = (body.quizResults.score / body.quizResults.total) >= 0.7;\nvar nodeColor = calculatedMastery >= 70 ? 'mastered' : 'learning';\nvar xpEarned = body.quizResults.score * 20;\n\nreturn {\n  body: body,\n  calculatedMastery: calculatedMastery,\n  previousMastery: previousMastery,\n  passed: passed,\n  nodeColor: nodeColor,\n  xpEarned: xpEarned\n};"
            },
            "id": "edc8e0ab-6477-4408-a5d8-c93d78e38a69",
            "name": "Mastery Calculator",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                -720,
                192
            ]
        },
        {
            "parameters": {
                "promptType": "define",
                "text": "=Pre-calculated values (include these EXACTLY in your output):\nmasteryScore: {{ $json.calculatedMastery }}\npreviousMastery: {{ $json.previousMastery }}\nnodeColorUpdate: {{ $json.nodeColor }}\nxpEarned: {{ $json.xpEarned }}\npassed: {{ $json.passed }}\n\nContext for recommendations:\nUser ID: {{ $json.body.userId }}\nTopic ID: {{ $json.body.topicId }}\nCurrent Topic: {{ $json.body.topicName }}\nWrong Questions: {{ JSON.stringify($json.body.quizResults.wrongQuestions) }}\nExam Date: {{ $json.body.examDate }}\nAll Topic Masteries: {{ JSON.stringify($json.body.allTopicMasteries) }}\n\nGenerate the full structured response now.",
                "hasOutputParser": true,
                "messages": {
                    "messageValues": [
                        {
                            "type": "system",
                            "message": "You are a Progress Tracking and Study Planning AI.\n\nThe following values have been PRE-CALCULATED. You MUST include them EXACTLY as given in your output — do not recalculate:\n- masteryScore: the pre-calculated value from input\n- masteryDelta.before: the previousMastery value from input\n- masteryDelta.after: same as masteryScore\n- nodeColorUpdate: the nodeColor from input (one of: unstarted, learning, mastered)\n- xpEarned: the pre-calculated value from input\n- passed: the pre-calculated boolean from input\n\nYour ONLY tasks are:\n1. Select the next best topic from allTopicMasteries (lowest mastery score first).\n   - If examDate is set and < 7 days away: prioritize the weakest topics.\n2. If examDate is set: generate a day-by-day rescue plan.\n   - Assign 1-2 topics per day based on estimated study time.\n   - Weakest topics get more time per day.\n   - Final day = Mock Exam from all topics.\n3. If examDate is not set, return an empty studyPlanUpdate: {}.\n\nYour output must exactly match the required JSON schema."
                        }
                    ]
                }
            },
            "id": "b7f6e257-ecb6-4482-8e4e-b9ad3d8ed937",
            "name": "Progress & Planning Agent",
            "type": "@n8n/n8n-nodes-langchain.chainLlm",
            "typeVersion": 1.4,
            "position": [
                -464,
                192
            ]
        },
