                "jsCode": "var llmOutput = $input.item.json;\nvar calcData = $('Mastery Calculator').item.json;\n\nreturn {\n  userId: calcData.body.userId,\n  topicId: calcData.body.topicId,\n  masteryScore: llmOutput.masteryScore,\n  nodeColorUpdate: llmOutput.nodeColorUpdate,\n  xpEarned: llmOutput.xpEarned,\n  passed: llmOutput.passed,\n  masteryDelta: llmOutput.masteryDelta,\n  nextTopicRecommendation: llmOutput.nextTopicRecommendation,\n  studyPlanUpdate: llmOutput.studyPlanUpdate,\n  lastStudiedAt: new Date().toISOString()\n};"
            },
