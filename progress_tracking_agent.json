        {
            "parameters": {
                "jsonSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"masteryScore\": { \"type\": \"number\" },\n    \"masteryDelta\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"before\": { \"type\": \"number\" },\n        \"after\": { \"type\": \"number\" }\n      },\n      \"required\": [\"before\", \"after\"]\n    },\n    \"nodeColorUpdate\": {\n      \"type\": \"string\",\n      \"enum\": [\"unstarted\", \"learning\", \"mastered\"]\n    },\n    \"xpEarned\": { \"type\": \"number\" },\n    \"passed\": { \"type\": \"boolean\" },\n    \"nextTopicRecommendation\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"topicId\": { \"type\": \"string\" },\n        \"topicName\": { \"type\": \"string\" },\n        \"reason\": { \"type\": \"string\" }\n      },\n      \"required\": [\"topicId\", \"topicName\", \"reason\"]\n    },\n    \"studyPlanUpdate\": {\n      \"type\": \"object\",\n      \"additionalProperties\": {\n        \"type\": \"array\",\n        \"items\": { \"type\": \"string\" }\n      }\n    }\n  },\n  \"required\": [\"masteryScore\", \"masteryDelta\", \"nodeColorUpdate\", \"xpEarned\", \"passed\", \"nextTopicRecommendation\", \"studyPlanUpdate\"]\n}"
            },
